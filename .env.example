# Copy this file to .env and fill in your values

# ===== AI PROVIDER CONFIGURATION =====
# Choose your AI provider: openai | gemini | ollama | openrouter | groq | custom
AI_PROVIDER=openai

# Model to use (leave empty for provider default)
# Examples: gpt-4o-mini, gemini-2.0-flash, llama3.2, llama-3.3-70b-versatile
AI_MODEL=

# API Keys (only set the one for your chosen provider)
OPENAI_API_KEY=sk-your-openai-key
GEMINI_API_KEY=your-gemini-key
GROQ_API_KEY=your-groq-key
OPENROUTER_API_KEY=your-openrouter-key

# For custom provider or Ollama:
# AI_BASE_URL=http://localhost:11434/v1
# AI_API_KEY=your-key

# ===== WALLET =====
# WDK Wallet seed phrase (will be generated on first run if empty)
WALLET_SEED_PHRASE=

# Network: "testnet" or "mainnet"
NETWORK=testnet

# ===== AGENT =====
# Server port
PORT=3000

# Yield threshold: agent will act if yield difference is above this (in %)
YIELD_THRESHOLD=1.0

# Agent check interval in minutes
AGENT_INTERVAL_MINUTES=1
